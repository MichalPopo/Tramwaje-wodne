# Tramwaje Wodne — Zmienne środowiskowe
# Skopiuj ten plik jako .env i uzupełnij wartości

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=24h

# Gemini AI (Google AI Studio)
# Uzyskaj klucz: https://ai.google.dev
GEMINI_API_KEY=

# Turso (Cloud SQLite)
# Uzyskaj klucze: https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# OpenWeatherMap
# Uzyskaj klucz: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# Lokalizacja (Tolkmicko)
WEATHER_LAT=54.3153
WEATHER_LON=19.5314

# Sezon
SEASON_START_DATE=2026-04-26
